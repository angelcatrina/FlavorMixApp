<?xml version="1.0" encoding="utf-8"?>
<!-- Simpan di: res/values-night/themes.xml -->
<resources>
    <style name="Theme.YumRecipe" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Warna brand disesuaikan untuk dark mode — tetap hijau -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & surface gelap -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">@color/textPrimary</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>